  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cbd832e09682aec4795b86945347c45d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  characterName: "\u0421\u043F\u0443\u0442\u043D\u0438\u0446\u0430"
  characterPortrait: {fileID: 0}
  dialogueLines:
  - speakerName: "\u0421\u043F\u0443\u0442\u043D\u0438\u0446\u0430"
    text: "\u042D\u0442\u043E \u0443\u0436\u0430\u0441\u043D\u043E! \u0414\u044F\u0434\u044F
      \u043E\u0441\u0442\u0430\u0432\u0438\u043B \u043C\u043D\u0435 \u043E\u0433\u0440\u043E\u043C\u043D\u043E\u0435
      \u043D\u0430\u0441\u043B\u0435\u0434\u0441\u0442\u0432\u043E, \u0430 \u0442\u0435\u043F\u0435\u0440\u044C
      \u043A\u0442\u043E-\u0442\u043E \u043F\u044B\u0442\u0430\u043B\u0441\u044F
      \u043C\u0435\u043D\u044F \u043E\u0442\u0440\u0430\u0432\u0438\u0442\u044C?
      \u0414\u0443\u043C\u0430\u0435\u0442\u0435, \u044D\u0442\u043E \u0438\u0437-\u0437\u0430
      \u0434\u0435\u043D\u0435\u0433?"
  cluesToGive:
  - "\u0421\u043F\u0443\u0442\u043D\u0438\u0446\u0430 \u2014 \u0431\u043E\u0433\u0430\u0442\u0430\u044F
    \u043D\u0430\u0441\u043B\u0435\u0434\u043D\u0438\u0446\u0430, \u0432\u043E\u0437\u043C\u043E\u0436\u043D\u043E,
    \u043E\u043D\u0430 \u0431\u044B\u043B\u0430 \u043D\u0430\u0441\u0442\u043E\u044F\u0449\u0435\u0439
    \u0446\u0435\u043B\u044C\u044E"
