--- !u!114 &982324172
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 982324168}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cbd832e09682aec4795b86945347c45d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  characterName: "\u0421\u0443-\u0448\u0435\u0444"
  characterPortrait: {fileID: 0}
  dialogueLines:
  - speakerName: "\u0421\u0443-\u0448\u0435\u0444"
    text: "\u042D\u0442\u043E\u0442 \u043A\u0440\u0438\u0442\u0438\u043A \u0443\u043D\u0438\u0437\u0438\u043B
      \u043C\u043E\u0451 \u0444\u0438\u0440\u043C\u0435\u043D\u043D\u043E\u0435 \u0431\u043B\u044E\u0434\u043E
      \u0432 \u0441\u0432\u043E\u0435\u0439 \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u0438.
      \u041D\u0430\u0437\u0432\u0430\u043B \u0435\u0433\u043E \"\u043F\u043E\u0437\u043E\u0440\u043E\u043C
      \u043A\u0443\u043B\u0438\u043D\u0430\u0440\u0438\u0438\"! \u0418\u0437-\u0437\u0430
      \u043D\u0435\u0433\u043E \u043C\u0435\u043D\u044F \u0447\u0443\u0442\u044C
      \u043D\u0435 \u0443\u0432\u043E\u043B\u0438\u043B\u0438."
  - speakerName: "\u0421\u0443-\u0448\u0435\u0444"
    text: "\u041D\u043E \u044F \u043D\u0435 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E
      \u0431\u0435\u0437\u0443\u043C\u0435\u043D, \u0447\u0442\u043E\u0431\u044B
      \u0442\u0440\u0430\u0432\u0438\u0442\u044C \u043B\u044E\u0434\u0435\u0439.
      \u0425\u043E\u0442\u044F \u043F\u0440\u0438\u0437\u043D\u0430\u044E\u0441\u044C,
      \u0432 \u0442\u043E\u0442 \u0432\u0435\u0447\u0435\u0440 \u044F \u043E\u0442\u0432\u043B\u0451\u043A\u0441\u044F
      \u0438 \u043F\u0435\u0440\u0435\u0431\u043E\u0440\u0449\u0438\u043B \u0441\u043E
      \u0441\u043F\u0435\u0446\u0438\u044F\u043C\u0438 \u0432 \u0431\u043E\u0431\u0430\u0445."
  cluesToGive:
  - "\u0421\u0443-\u0448\u0435\u0444 \u0437\u0430\u0442\u0430\u0438\u043B \u043E\u0431\u0438\u0434\u0443
    \u043D\u0430 \u043A\u0440\u0438\u0442\u0438\u043A\u0430 \u0437\u0430 \u0443\u043D\u0438\u0437\u0438\u0442\u0435\u043B\u044C\u043D\u0443\u044E
    \u0440\u0435\u0446\u0435\u043D\u0437\u0438\u044E"
  - "\u0421\u0443-\u0448\u0435\u0444 \u043F\u0440\u0438\u0437\u043D\u0430\u043B\u0441\u044F,
    \u0447\u0442\u043E \u043E\u0442\u0432\u043B\u0451\u043A\u0441\u044F \u0432\u043E
    \u0432\u0440\u0435\u043C\u044F \u0433\u043E\u0442\u043E\u0432\u043A\u0438 \u0431\u043E\u0431\u043E\u0432"
