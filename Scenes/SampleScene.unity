--- !u!114 &2021160830
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 2021160825}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cbd832e09682aec4795b86945347c45d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  characterName: "\u0428\u0435\u0444-\u043F\u043E\u0432\u0430\u0440"
  characterPortrait: {fileID: 0}
  dialogueLines:
  - speakerName: "\u0428\u0435\u0444-\u043F\u043E\u0432\u0430\u0440"
    text: "\u0414\u0435\u0442\u0435\u043A\u0442\u0438\u0432, \u044D\u0442\u043E\u0442
      \u043A\u0440\u0438\u0442\u0438\u043A \u043C\u0435\u043D\u044F \u0434\u043E\u0441\u0442\u0430\u043B!
      \u0413\u043E\u0434 \u043D\u0430\u0437\u0430\u0434 \u043E\u043D \u0440\u0430\u0437\u043D\u0451\u0441
      \u043C\u043E\u0439 \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D \u0432
      \u043F\u0443\u0445 \u0438 \u043F\u0440\u0430\u0445. \u042F \u0435\u0433\u043E
      \u043D\u0435\u043D\u0430\u0432\u0438\u0436\u0443!"
  - speakerName: "\u0428\u0435\u0444-\u043F\u043E\u0432\u0430\u0440"
    text: "\u041D\u043E \u044F \u043D\u0435 \u0443\u0431\u0438\u0439\u0446\u0430,
      \u0447\u0435\u0441\u0442\u043D\u043E! \u041F\u0440\u043E\u0432\u0435\u0440\u044C\u0442\u0435
      \u043F\u0435\u0440\u0441\u043E\u043D\u0430\u043B \u043D\u0430 \u043A\u0443\u0445\u043D\u0435.
      \u0412 \u0434\u0435\u043D\u044C \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0442\u0432\u043E\u0440\u0438\u043B\u043E\u0441\u044C \u0447\u0442\u043E-\u0442\u043E
      \u0441\u0442\u0440\u0430\u043D\u043D\u043E\u0435."
  cluesToGive:
  - "\u0428\u0435\u0444 \u043D\u0435\u043D\u0430\u0432\u0438\u0434\u0435\u043B \u043A\u0440\u0438\u0442\u0438\u043A\u0430
    \u0437\u0430 \u0440\u0430\u0437\u0433\u0440\u043E\u043C\u043B\u0435\u043D\u043D\u044B\u0439
    \u0440\u0435\u0441\u0442\u043E\u0440\u0430\u043D"
  - "\u0428\u0435\u0444 \u0441\u043E\u0432\u0435\u0442\u0443\u0435\u0442 \u043F\u0440\u043E\u0432\u0435\u0440\u0438\u0442\u044C
    \u043E\u0444\u0438\u0446\u0438\u0430\u043D\u0442\u0430"
