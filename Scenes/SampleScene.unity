  objectName: "\u041C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0435 \u0441 \u0444\u0440\u0443\u043A\u0442\u0430\u043C\u0438"
  clueName: "\u041F\u0435\u0440\u0435\u043F\u0443\u0442\u0430\u043D\u043D\u044B\u0435
    \u0442\u0430\u0440\u0435\u043B\u043A\u0438"
  clueDescription: "\u041C\u043E\u0440\u043E\u0436\u0435\u043D\u043E\u0435 \u0441
    \u0444\u0440\u0443\u043A\u0442\u0430\u043C\u0438 \u044F\u0432\u043D\u043E \u043F\u0440\u0435\u0434\u043D\u0430\u0437\u043D\u0430\u0447\u0430\u043B\u043E\u0441\u044C
    \u0441\u043F\u0443\u0442\u043D\u0438\u0446\u0435 \u043A\u0440\u0438\u0442\u0438\u043A\u0430,
    \u0430 \u043D\u0435 \u0435\u043C\u0443 \u0441\u0430\u043C\u043E\u043C\u0443.
    \u041A\u0442\u043E-\u0442\u043E \u043F\u0435\u0440\u0435\u0441\u0442\u0430\u0432\u0438\u043B
    \u0442\u0430\u0440\u0435\u043B\u043A\u0438."
  hasSecondInspection: 1
  secondClueName: "\u0411\u0435\u043B\u044B\u0439 \u043F\u043E\u0440\u043E\u0448\u043E\u043A
    \u0432 \u0434\u0435\u0441\u0435\u0440\u0442\u0435"
  secondClueDescription: "\u041F\u043E\u0434 \u0441\u043B\u043E\u0435\u043C \u0434\u0440\u0430\u0436\u0435
    \u0438 \u0444\u0440\u0443\u043A\u0442\u043E\u0432 \u0432\u0438\u0434\u0435\u043D
    \u0431\u0435\u043B\u044B\u0439 \u043F\u043E\u0440\u043E\u0448\u043E\u043A. \u041E\u043F\u0440\u0435\u0434\u0435\u043B\u0451\u043D\u043D\u043E
    \u043D\u0435 \u0441\u0430\u0445\u0430\u0440\u043D\u0430\u044F \u043F\u0443\u0434\u0440\u0430."
