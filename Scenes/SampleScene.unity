--- !u!114 &1384848111
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1384848107}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: cbd832e09682aec4795b86945347c45d, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::NPCDialogue
  characterName: "\u041E\u0444\u0438\u0446\u0438\u0430\u043D\u0442"
  characterPortrait: {fileID: 0}
  dialogueLines:
  - speakerName: "\u041E\u0444\u0438\u0446\u0438\u0430\u043D\u0442"
    text: "\u042F? \u042F \u043F\u0440\u043E\u0441\u0442\u043E \u043F\u043E\u0434\u0430\u0432\u0430\u043B
      \u0431\u043B\u044E\u0434\u0430. \u041D\u0438\u0447\u0435\u0433\u043E \u043D\u0435
      \u0437\u043D\u0430\u044E \u043E\u0431 \u043E\u0442\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u0438."
  - speakerName: "\u041E\u0444\u0438\u0446\u0438\u0430\u043D\u0442"
    text: "\u0414\u0435\u0441\u0435\u0440\u0442? \u0414\u0430, \u044F \u043F\u043E\u0434\u0430\u0432\u0430\u043B
      \u0434\u0435\u0441\u0435\u0440\u0442... \u041D\u043E \u044D\u0442\u043E \u0431\u044B\u043B\u0430
      \u043E\u0431\u044B\u0447\u043D\u0430\u044F \u0442\u0430\u0440\u0435\u043B\u043A\u0430.
      \u0418\u0437\u0432\u0438\u043D\u0438\u0442\u0435, \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u043E
      \u043D\u0430 \u043A\u0443\u0445\u043D\u044E."
  cluesToGive: []
